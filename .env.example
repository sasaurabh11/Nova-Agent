LLM_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UNCERTAIN_THRESHOLD=0.70       # field confidence below this -> uncertain
AUTO_APPROVE_THRESHOLD=0.85    # ALL fields must clear this to auto-approve
MAX_LLM_RETRIES=2              # bounded retries (no infinite loops)
LLM_TIMEOUT_S=60               # per-call timeout
SHIPMENT_BUDGET_S=180          # hard wall-clock budget per shipment
DB_PATH=./data/nova.db
#(https://myaccount.google.com/apppasswords)
EMAIL_USER=                    # e.g. cg-team@yourdomain.com
EMAIL_PASSWORD=                # app password (NOT your normal password)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_FOLDER=INBOX
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
POLL_INTERVAL_S=30             # how often to check the mailbox for new mail
DEFAULT_CUSTOMER_ID=cust_acme  # customer applied to incoming email (POC default)
IMAP_SEARCH=
MAX_FETCH_PER_POLL=5
MAX_TOTAL_FETCH=5
