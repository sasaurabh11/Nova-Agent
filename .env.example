LLM_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UNCERTAIN_THRESHOLD=0.70       # field confidence below this -> uncertain
AUTO_APPROVE_THRESHOLD=0.85    # ALL fields must clear this to auto-approve
MAX_LLM_RETRIES=2              # bounded retries (no infinite loops)
LLM_TIMEOUT_S=60               # per-call timeout
SHIPMENT_BUDGET_S=180          # hard wall-clock budget per shipment
DB_PATH=./data/nova.db
